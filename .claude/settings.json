{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "staged=$(git diff --cached --name-only --diff-filter=d -- '*.rs'); if [ -n \"$staged\" ]; then echo \"$staged\" | xargs rustfmt && echo \"$staged\" | xargs git add; fi"
          }
        ]
      }
    ]
  },
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["gh", "trunk"],
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "crates.io",
        "docs.rs",
        "lib.rs",
        "book.leptos.dev",
        "trunkrs.dev",
        "rustwasm.github.io",
        "developer.chrome.com",
        "raw.githubusercontent.com"
      ]
    }
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:lib.rs)",
      "WebFetch(domain:book.leptos.dev)",
      "WebFetch(domain:trunkrs.dev)",
      "WebFetch(domain:rustwasm.github.io)",
      "WebFetch(domain:developer.chrome.com)"
    ]
  }
}
